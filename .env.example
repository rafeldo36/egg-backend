# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_key_here

# ============================================
# Twilio SMS/WhatsApp Configuration (FREE)
# ============================================
# Get free Twilio account at: https://www.twilio.com/try-twilio
# Free tier includes $15 credit (500+ SMS messages)

# Your unique Twilio Account SID
# Found at: https://www.twilio.com/console
# Format: ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio Auth Token (keep this SECRET - don't commit to git!)
# Found at: https://www.twilio.com/console
# Shows when you click the eye icon next to "Auth Token"
TWILIO_AUTH_TOKEN=your_full_auth_token_here

# Your Twilio Phone Number
# Assigned to you when you create account
# Format: +1234567890
TWILIO_PHONE_NUMBER=+1234567890

# Your Twilio WhatsApp Number
# Usually the same as TWILIO_PHONE_NUMBER
# Setup at: https://www.twilio.com/console/sms/whatsapp/learn
TWILIO_WHATSAPP_NUMBER=+1234567890

# ============================================
# Alternative Services (Optional)
# ============================================
# If you prefer not to use Twilio:
# 
# Vonage (Nexmo):
# - 10 SMS free per month
# - https://www.vonage.com/communications-apis/sms/
#
# MessageBird:
# - Free sandbox mode for testing
# - https://www.messagebird.com/
#
# AWS SNS:
# - 1000 SMS per month free tier
# - https://aws.amazon.com/sns/
